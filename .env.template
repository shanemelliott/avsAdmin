# AVS Admin User Class Report - Configuration Template
# Copy this to .env and update with your actual credentials

# ============================================================
# VistA API-X Configuration
# ============================================================
VISTA_BASE_URL=https://cds.med.va.gov/vista-api-x
VISTA_API_KEY=your_api_key_here
VISTA_TIMEOUT=60000
VISTA_CONTEXT=OR CPRS GUI CHART

# ============================================================
# Report Configuration
# ============================================================
OUTPUT_DIR=./results

# DUZ Accounts File
# Use 'accounts.csv' for production, 'accountsStage.csv' for staging
ACCOUNTS_FILE=accounts.csv

# User Class Search Pattern
# Pattern to search for user classes (e.g., "AVS" finds AVS ADMINISTRATOR, AVS BATCH PRINT)
SEARCH_PATTERN=AVS
